# Cloudflare static-asset response headers.
# https://developers.cloudflare.com/workers/static-assets/headers/

/*
  # RFC 8288 Link headers for agent/crawler discovery (real, existing resources only).
  Link: </sitemap.xml>; rel="sitemap"; type="application/xml"
  Link: </privacy.html>; rel="privacy-policy"
  # Security headers.
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
