{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pitmaster-command-center",
  "compatibility_date": "2026-07-11",
  "observability": {
    "enabled": true
  },
  // Serve the Astro static build output (`dist/`) rather than the repo root.
  "assets": {
    "directory": "./dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
