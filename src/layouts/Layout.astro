---
/*
 * Base layout for every Empirical BBQ page.
 * Owns the shared <head> (SEO + Google Analytics + AdSense loader), the global
 * navigation header, the persistent bottom banner ad, and the page chrome that
 * was previously copy-pasted across all the standalone HTML files.
 */
import Nav from '../components/Nav.astro';
import AdSlot from '../components/AdSlot.astro';

export interface Props {
  title: string;
  description: string;
  ogUrl: string;
  /** @deprecated No longer used — the site now serves the hosted brand favicon. Kept so existing page props don't error. */
  favicon?: string;
  active?: 'home' | 'brisket' | 'stall' | 'fuel' | 'scheduler' | 'blog' | 'contact' | null;
  /** Classes applied to <body> so each page keeps its background/text scheme. */
  bodyClass?: string;
  /** Render the sticky 728x90 bottom banner (all tools; off for the privacy page). */
  showBanner?: boolean;
  /** Absolute URL of the social-share image (og:image / twitter:image). */
  ogImage?: string;
  /** Page-specific JSON-LD structured data — a single object or an array of objects. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogUrl,
  active = null,
  bodyClass = 'min-h-screen bg-base-850 text-base-300 font-display antialiased',
  showBanner = true,
  ogImage = 'https://empiricalbbq.com/og-default.png',
  schema,
} = Astro.props;

// Site-wide WebSite schema, always present; page schema (if any) is appended.
const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Empirical BBQ',
  url: 'https://empiricalbbq.com/',
  publisher: {
    '@type': 'Organization',
    name: 'Empirical BBQ',
    url: 'https://empiricalbbq.com/',
    logo: 'https://empiricalbbq.com/android-chrome-512x512.png',
  },
};
const schemaBlocks = [siteSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];

// Serialize JSON-LD safely: escape characters that could break out of the
// <script> element or act as JS line terminators (defense-in-depth; schema is
// author-defined, not user input). Unicode escapes stay valid inside JSON.
const JSONLD_UNSAFE = /[<>&\u2028\u2029]/g;
const jsonLd = (block) =>
  JSON.stringify(block).replace(JSONLD_UNSAFE, (c) => '\\u' + c.charCodeAt(0).toString(16).padStart(4, '0'));
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <!-- Google tag (gtag.js) + Consent Mode v2 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Q5WHQ3GPHC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      // Consent Mode v2: deny ad + analytics storage by default until the user opts in.
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
      });
      // Honor a previously stored choice before GA/AdSense initialize.
      try {
        if (localStorage.getItem('pitmaster_consent') === 'granted') {
          gtag('consent', 'update', {
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted',
            analytics_storage: 'granted',
          });
        }
      } catch (e) {}
      // NOTE: For EEA/UK AdSense monetization Google requires a certified
      // Consent Management Platform (CMP). This lightweight self-hosted banner
      // is an interim measure only — for production EEA/UK ad serving, adopt a
      // certified CMP from https://support.google.com/admob/answer/13554116
      gtag('js', new Date());
      gtag('config', 'G-Q5WHQ3GPHC');
    </script>
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4455664783992058"
      crossorigin="anonymous"></script>
    <meta name="google-adsense-account" content="ca-pub-4455664783992058" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="canonical" href={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <!-- Hosted brand favicon set (Google Search, browser tabs, iOS/Android home screens). -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#121824" />
    <link rel="alternate" type="application/rss+xml" title="Empirical BBQ Blog" href="https://empiricalbbq.com/rss.xml" />
    {schemaBlocks.map((block) => (
      <script type="application/ld+json" set:html={jsonLd(block)} />
    ))}
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <Nav active={active} />

    <slot />

    {
      showBanner && (
        <div id="stickyAd" class="sticky bottom-0 left-0 right-0 z-50 pointer-events-none">
          <div class="mx-auto flex w-full max-w-3xl flex-col items-center">
            {/* Minimize / restore tab — always visible so the ad can be reclaimed on small screens */}
            <button
              id="stickyAdToggle"
              type="button"
              aria-controls="stickyAdPanel"
              aria-expanded="true"
              class="pointer-events-auto flex items-center gap-1 rounded-t-md border border-b-0 border-gray-800 bg-[#0d121b]/95 px-3 py-0.5 text-[9px] font-mono uppercase tracking-widest text-base-500 backdrop-blur-md transition-colors hover:text-base-300"
            >
              <span id="stickyAdToggleLabel">Hide ad</span>
              <svg id="stickyAdChevron" class="h-3 w-3 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            {/* Height-capped, clipped panel: an oversized ad can never dominate the viewport */}
            <div
              id="stickyAdPanel"
              class="pointer-events-auto flex w-full max-h-[80px] flex-col items-center justify-center overflow-hidden border-t border-gray-800 bg-[#0d121b]/95 p-1 shadow-[0_-10px_25px_-5px_rgba(0,0,0,0.5)] backdrop-blur-md transition-[max-height] duration-300 ease-in-out sm:max-h-[96px]"
            >
              <div class="text-[8px] font-mono tracking-widest text-base-600 uppercase mb-0.5">Advertisement</div>
              <AdSlot
                slotId="global-banner-728x90"
                format="horizontal"
                fullWidthResponsive={false}
                class="w-full max-w-[728px] h-[50px] sm:h-[60px] px-4"
                style="display:block;width:100%;max-width:728px;height:60px"
              />
            </div>
          </div>
        </div>
      )
    }

    {
      showBanner && (
        <script is:inline>
          (function () {
            var KEY = 'pitmaster_ad_hidden';
            var panel = document.getElementById('stickyAdPanel');
            var toggle = document.getElementById('stickyAdToggle');
            var label = document.getElementById('stickyAdToggleLabel');
            var chevron = document.getElementById('stickyAdChevron');
            if (!panel || !toggle) return;

            function apply(hidden, animate) {
              if (!animate) panel.style.transition = 'none';
              panel.style.maxHeight = hidden ? '0px' : '';
              panel.style.paddingTop = hidden ? '0px' : '';
              panel.style.paddingBottom = hidden ? '0px' : '';
              toggle.setAttribute('aria-expanded', hidden ? 'false' : 'true');
              if (label) label.textContent = hidden ? 'Show ad' : 'Hide ad';
              if (chevron) chevron.style.transform = hidden ? 'rotate(180deg)' : '';
              if (!animate) { void panel.offsetHeight; panel.style.transition = ''; }
            }

            var start = false;
            try { start = localStorage.getItem(KEY) === '1'; } catch (e) {}
            apply(start, false);

            toggle.addEventListener('click', function () {
              var hidden = toggle.getAttribute('aria-expanded') === 'true';
              apply(hidden, true);
              try { localStorage.setItem(KEY, hidden ? '1' : '0'); } catch (e) {}
            });
          })();
        </script>
      )
    }

    {/* Self-hosted consent banner (Consent Mode v2). Interim measure — see the NOTE in <head>. */}
    <div id="consentBanner" class="hidden fixed inset-x-0 bottom-0 z-[60] p-3 sm:p-4 pointer-events-none">
      <div class="pointer-events-auto mx-auto max-w-3xl rounded-xl bg-base-850 ring-1 ring-base-700 shadow-2xl shadow-black/60 p-4 sm:p-5 flex flex-col sm:flex-row sm:items-center gap-3">
        <p class="flex-1 text-[13px] text-base-300 leading-relaxed">
          We use cookies for analytics and to show relevant ads. You can accept or reject non-essential
          cookies — see our <a href="/privacy" class="text-amber-400 hover:text-amber-300 underline">privacy policy</a>.
        </p>
        <div class="flex gap-2 shrink-0">
          <button id="consentReject" type="button" class="rounded-lg bg-base-800 ring-1 ring-base-700 hover:ring-base-600 text-base-300 hover:text-white font-semibold text-xs px-4 py-2 transition-all">
            Reject
          </button>
          <button id="consentAccept" type="button" class="rounded-lg bg-amber-500 hover:bg-amber-400 text-base-900 font-bold text-xs px-4 py-2 transition-colors">
            Accept
          </button>
        </div>
      </div>
    </div>
    <script is:inline>
      (function () {
        var KEY = 'pitmaster_consent';
        var banner = document.getElementById('consentBanner');
        if (!banner) return;
        var stored = null;
        try { stored = localStorage.getItem(KEY); } catch (e) {}
        if (stored === 'granted' || stored === 'denied') return; // choice already made
        banner.classList.remove('hidden');

        function choose(value) {
          try { localStorage.setItem(KEY, value); } catch (e) {}
          if (value === 'granted' && typeof gtag === 'function') {
            gtag('consent', 'update', {
              ad_storage: 'granted',
              ad_user_data: 'granted',
              ad_personalization: 'granted',
              analytics_storage: 'granted',
            });
          }
          banner.classList.add('hidden');
        }
        document.getElementById('consentAccept').addEventListener('click', function () { choose('granted'); });
        document.getElementById('consentReject').addEventListener('click', function () { choose('denied'); });
      })();
    </script>
  </body>
</html>
