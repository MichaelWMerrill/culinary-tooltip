---
/*
 * Shared responsive navigation header.
 * `active` highlights the current page: 'home' | 'brisket' | 'stall' | 'fuel' | 'scheduler' | 'blog' | 'contact'.
 */
export interface Props {
  active?: 'home' | 'brisket' | 'stall' | 'fuel' | 'scheduler' | 'blog' | 'contact' | null;
}
const { active = null } = Astro.props;

// Absolute (root-relative), extensionless canonical hrefs so the nav resolves
// correctly from nested routes too — e.g. blog posts served under /blog/<slug>.
const links = [
  { key: 'brisket', href: '/brisket-calculator', label: 'Brisket' },
  { key: 'stall', href: '/stall-predictor', label: 'Stall' },
  { key: 'fuel', href: '/fuel-estimator', label: 'Fuel' },
  { key: 'scheduler', href: '/cook-scheduler', label: 'Scheduler' },
  { key: 'blog', href: '/blog', label: 'Blog' },
  { key: 'contact', href: '/contact', label: 'Contact' },
];

const inactiveCls =
  'text-gray-400 hover:text-white hover:bg-white/5 rounded-md px-3 py-1.5 whitespace-nowrap transition-colors';
const activeCls =
  'bg-[#f59e0b]/15 text-[#f59e0b] ring-1 ring-[#f59e0b]/40 rounded-md px-3 py-1.5 whitespace-nowrap transition-colors';
---

<nav class="relative z-10 bg-[#121824] border-b border-gray-800 px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
  <a
    href="/"
    aria-current={active === 'home' ? 'page' : undefined}
    class="text-[#f59e0b] hover:text-[#f97316] font-bold tracking-wide flex items-center gap-2 transition-colors shrink-0"
  >
    <span aria-hidden="true">🔥</span><span class="hidden sm:inline">PITMASTER</span>
  </a>
  <div class="flex items-center gap-1 overflow-x-auto text-xs font-medium">
    {
      links.map((l) => (
        <a
          href={l.href}
          aria-current={active === l.key ? 'page' : undefined}
          class={active === l.key ? activeCls : inactiveCls}
        >
          {l.label}
        </a>
      ))
    }
  </div>
</nav>
