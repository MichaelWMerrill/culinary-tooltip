---
/*
 * CookScheduler — the back-calculating cook scheduler as a reusable component.
 * Takes a `protein` prop (default beef_brisket); the meat-weight input is
 * rendered from that protein's `thermal.axes`. Pit / wrap / climate / rest are
 * equipment/environment and stay component-local. Client wiring lives in
 * ./cookScheduler.controller.js.
 */
import { PROTEINS } from '../../utils/proteinRegistry.js';
import ProteinSelector from './ProteinSelector.astro';
import GearModule from './GearModule.astro';

export interface Props {
  protein?: (typeof PROTEINS)[keyof typeof PROTEINS];
}

const { protein = PROTEINS.beef_brisket } = Astro.props;

// The scheduler is one page; the protein is chosen client-side via ?pr=. So we
// render the union of every scheduler protein's thermal controls and the
// controller shows the active set. Weight is the default (brisket/pork);
// ribs' cut+racks are present but hidden until selected.
const schedulerIds = ['beef_brisket', 'pork_shoulder', 'pork_ribs'];
const axisById = {};
for (const id of schedulerIds) for (const a of PROTEINS[id].thermal.axes) if (!axisById[a.id]) axisById[a.id] = a;
const unionAxes = Object.values(axisById);
// Pit temps offered = union of the scheduler proteins' registry temps (turkey is
// not a scheduler protein, so its 300/325 don't appear here). Rendered, not hardcoded.
const pitTemps = [...new Set(schedulerIds.flatMap((id) => Object.keys(PROTEINS[id].thermal.cook_temperatures)))].sort(
  (a, b) => a - b
);
const tInit = { weight: 12, cut: 'spare', racks: 3 };
const tCopy = { ...(PROTEINS.pork_ribs.thermal.copy || {}) };
const segCols = (c) => (c === 2 ? 'grid-cols-2' : 'grid-cols-3');
// Axis ids that ship visible by default (weight); others start hidden.
const defaultVisible = new Set(['weight']);
---

  <div class="relative z-10 flex-1 w-full">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <ProteinSelector tool="scheduler" current={protein.meta.id} interactive={true} />
      <header class="mb-8 flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-flame-500/15 ring-1 ring-flame-500/40 text-2xl">🗓️</div>
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-white">Cook Scheduler</h1>
            <p class="text-sm text-base-400 mt-0.5">Tell it when you want to eat — it back-calculates when to light the fire</p>
          </div>
        </div>
        <button id="shareBtn" type="button" class="shrink-0 inline-flex items-center gap-1.5 rounded-lg bg-base-800 ring-1 ring-base-700 hover:ring-flame-500/50 text-base-300 hover:text-white text-xs font-semibold px-3.5 py-2 transition-all">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
          <span data-copy-label>Copy share link</span>
        </button>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <!-- ============ INPUTS ============ -->
        <section class="lg:col-span-5 rounded-2xl bg-base-800/70 ring-1 ring-base-700 shadow-xl shadow-black/40 p-5 sm:p-6 space-y-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-flame-400">The Plan</h2>

          <div>
            <label for="serveAt" class="block text-sm font-medium text-base-300 mb-2">When do you want to eat?</label>
            <input id="serveAt" type="datetime-local" class="w-full rounded-lg bg-base-900 border border-base-700 px-3 py-2.5 text-sm text-white focus:outline-none focus:ring-1 focus:ring-flame-500 transition-all" />
          </div>

          {
            /* Union of scheduler proteins' thermal inputs; controller shows the
               active set (weight for brisket/pork, cut+racks for ribs). */
            unionAxes.map((axis) => (
              <div data-thermal-axis={axis.id} hidden={!defaultVisible.has(axis.id)}>
                {axis.type === 'slider' && (
                  <Fragment>
                    <div class="flex items-baseline justify-between mb-2">
                      <label for={axis.id} class="text-sm font-medium text-base-300">{axis.label}</label>
                      <span class="text-sm font-mono"><span id={`${axis.id}Val`} class="text-white font-semibold">{Number(tInit[axis.id]).toFixed(1)}</span> <span class="text-base-400">{axis.range.unit}</span></span>
                    </div>
                    <input id={axis.id} type="range" min={axis.range.min} max={axis.range.max} step={axis.range.step} value={tInit[axis.id]} class="w-full" />
                    <div class="flex justify-between text-[10px] text-base-500 mt-1 font-mono"><span id={`${axis.id}Min`}>{axis.range.min} {axis.range.unit}</span><span id={`${axis.id}Max`}>{axis.range.max} {axis.range.unit}</span></div>
                  </Fragment>
                )}
                {axis.type === 'enum' && axis.control === 'segmented' && (
                  <Fragment>
                    <label class="block text-sm font-medium text-base-300 mb-2">{axis.label}</label>
                    <div id={`${axis.id}Toggle`} aria-label={axis.label} class={`grid ${segCols(axis.cols)} gap-1 rounded-lg bg-base-900 ring-1 ring-base-700 p-1`} role="group">
                      {axis.options.map((o) => (
                        <button data-value={o.value} data-axis={axis.id} class={`${axis.id}-opt rounded-md px-2 py-2 text-xs font-medium transition-colors`} aria-pressed={o.value === tInit[axis.id] ? 'true' : 'false'}>{o.label}</button>
                      ))}
                    </div>
                    {axis.copy && <p id={`${axis.id}Desc`} class="text-[11px] text-base-500 mt-1.5 leading-snug" set:html={tCopy[axis.copy][tInit[axis.id]]} />}
                  </Fragment>
                )}
              </div>
            ))
          }

          <div>
            <label class="block text-sm font-medium text-base-300 mb-2">Target Pit Temp</label>
            <div id="pitTempToggle" class={`grid ${pitTemps.length > 3 ? 'grid-cols-3 sm:grid-cols-5' : 'grid-cols-3'} gap-1 rounded-lg bg-base-900 ring-1 ring-base-700 p-1`} role="group">
              {pitTemps.map((t, i) => (
                <button data-temp={t} class="temp-opt rounded-md px-1 py-2 text-sm font-medium transition-colors" aria-pressed={i === 0 ? 'true' : 'false'}>{t}&deg;F</button>
              ))}
            </div>
          </div>

          <div>
            <label for="pit" class="block text-sm font-medium text-base-300 mb-2">Pit Type</label>
            <select id="pit" class="w-full rounded-lg bg-base-900 border border-base-700 px-3 py-2.5 text-sm text-white focus:outline-none focus:ring-1 focus:ring-flame-500">
              <option value="pellet_cooker">Pellet Cooker</option>
              <option value="offset_smoker" selected>Offset Smoker</option>
              <option value="ceramic_kamado">Ceramic Kamado</option>
              <option value="charcoal_kettle">Charcoal Kettle</option>
            </select>
          </div>

          <div data-stall-only>
            <label class="block text-sm font-medium text-base-300 mb-2">Wrap Type</label>
            <div id="wrapToggle" class="grid grid-cols-3 gap-1 rounded-lg bg-base-900 ring-1 ring-base-700 p-1" role="group">
              <button data-wrap="none" class="wrap-opt rounded-md px-2 py-2 text-xs font-medium transition-colors" aria-pressed="false">No Wrap</button>
              <button data-wrap="peach_butcher_paper" class="wrap-opt rounded-md px-2 py-2 text-xs font-medium transition-colors" aria-pressed="true">Butcher Paper</button>
              <button data-wrap="aluminum_foil" class="wrap-opt rounded-md px-2 py-2 text-xs font-medium transition-colors" aria-pressed="false">Foil</button>
            </div>
          </div>

          <div id="wrapTempWrap" data-stall-only>
            <div class="flex items-baseline justify-between mb-2">
              <label for="wrapTemp" class="text-sm font-medium text-base-300">Wrap at Internal Temp</label>
              <span class="text-sm font-mono"><span id="wrapTempVal" class="text-white font-semibold">160</span><span class="text-base-400">&deg;F</span></span>
            </div>
            <input id="wrapTemp" type="range" min="150" max="170" step="1" value="160" class="w-full" />
          </div>

          <div data-stall-only>
            <label class="block text-sm font-medium text-base-300 mb-2">Regional Climate</label>
            <div id="climateToggle" class="grid grid-cols-3 gap-1 rounded-lg bg-base-900 ring-1 ring-base-700 p-1" role="group">
              <button data-climate="arid" class="climate-opt rounded-md px-1 py-2 text-[11px] font-medium transition-colors" aria-pressed="false">Arid</button>
              <button data-climate="moderate" class="climate-opt rounded-md px-1 py-2 text-[11px] font-medium transition-colors" aria-pressed="true">Moderate</button>
              <button data-climate="humid" class="climate-opt rounded-md px-1 py-2 text-[11px] font-medium transition-colors" aria-pressed="false">Humid</button>
            </div>
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <label for="rest" class="text-sm font-medium text-base-300">Rest Before Serving</label>
              <span class="text-sm font-mono"><span id="restVal" class="text-white font-semibold">1.0</span> <span class="text-base-400">hr</span></span>
            </div>
            <input id="rest" type="range" min="0.5" max="4" step="0.25" value="1" class="w-full" />
            <div class="flex justify-between text-[10px] text-base-500 mt-1 font-mono"><span>0.5 hr</span><span>4 hr</span></div>
            <p class="text-[11px] text-base-500 mt-1.5 leading-snug">Held in a faux-cambro (foil + towels in a cooler), a rest of an hour or more keeps the brisket safely above 140°F.</p>
          </div>
        </section>

        <!-- ============ SCHEDULE ============ -->
        <section class="lg:col-span-7 space-y-6">
          <div class="rounded-2xl bg-gradient-to-br from-flame-600/20 via-base-800 to-base-800 ring-1 ring-flame-500/40 shadow-xl shadow-black/40 p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-flame-300/90">Light the fire at</p>
                <p id="fireUpBig" class="mt-2 text-3xl sm:text-4xl font-extrabold text-white leading-none">—</p>
                <p id="totalSub" class="text-xs text-base-400 mt-2">—</p>
                <p class="text-[10px] font-mono text-base-500 mt-1.5">Model v<span id="modelVer">{protein.meta.version}</span> · cook time shown as a &plusmn;15&ndash;25% window (narrower with foil, wider unwrapped)</p>
                <p class="text-[11px] text-base-500 mt-1 leading-snug">These times are fitted to published field cook-time guidance, not logged from our own pit &mdash; a planning estimate, not a guarantee. Probe to temperature.</p>
                <p id="versionNotice" class="hidden text-[11px] text-amber-400/90 mt-1 leading-snug"></p>
                <p id="dangerZone" class="hidden text-[11px] mt-1 leading-snug"></p>
              </div>
              <div class="hidden sm:flex h-14 w-14 items-center justify-center rounded-xl bg-flame-500/15 ring-1 ring-flame-500/40 text-3xl">🔥</div>
            </div>
            <p id="warnBox" class="hidden mt-4 rounded-lg bg-amber-500/10 ring-1 ring-amber-500/40 px-3 py-2 text-[13px] text-amber-200"></p>
          </div>

          <div class="rounded-2xl bg-base-800/70 ring-1 ring-base-700 shadow-xl shadow-black/40 p-5 sm:p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-semibold text-white">Cook Timeline</h3>
              <button id="icsBtn" type="button" class="inline-flex items-center gap-1.5 rounded-lg bg-flame-600 hover:bg-flame-500 text-white font-bold text-xs px-3.5 py-2 transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                Add to calendar (.ics)
              </button>
            </div>
            <ol id="timeline" class="relative border-l border-base-700 ml-2 space-y-6"></ol>
          </div>

          <GearModule tool="scheduler" state={{ protein: protein.meta.id, pit: 'offset_smoker' }} />
        </section>
      </div>

      <footer class="mt-8 text-center text-[11px] text-base-500">
        <p>Schedule derives from the same phenomenological stall model as the <a href="/stall-predictor" class="text-flame-400 hover:text-flame-300 underline decoration-dotted underline-offset-2">Stall Predictor</a>. Real cooks vary &mdash; build in a buffer and probe your meat.</p>
        <p class="mt-2"><a href="/methodology" class="text-flame-400 hover:text-flame-300 underline decoration-dotted underline-offset-2">Methodology &amp; sources</a></p>
      </footer>
    </div>
  </div>

  <!-- Footer -->
  <footer class="relative z-10 border-t border-base-700 bg-base-900/70 backdrop-blur">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs font-medium text-base-400 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <a href="/brisket-calculator" class="hover:text-white transition-colors">Brisket Calculator</a>
        <a href="/stall-predictor" class="hover:text-white transition-colors">Stall Predictor</a>
        <a href="/fuel-estimator" class="hover:text-white transition-colors">Fuel Estimator</a>
        <a href="/cook-scheduler" class="text-flame-400 hover:text-flame-300 transition-colors">Cook Scheduler</a>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
      </nav>
      <div class="pt-6 border-t border-base-800 flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-xs text-base-500">&copy; 2026 Empirical BBQ · Pitmaster Science &amp; Mathematics Suite</p>
        <p class="text-[11px] text-base-600 font-mono">Estimates for planning only — always probe to temperature.</p>
      </div>
    </div>
  </footer>
<style is:global>
  body.page-scheduler::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(1200px 600px at 82% -12%, rgba(249, 115, 22, 0.14), transparent 60%),
      radial-gradient(950px 520px at -8% 108%, rgba(245, 158, 11, 0.09), transparent 55%);
  }
  body.page-scheduler input[type='range'] {
    -webkit-appearance: none;
    appearance: none;
    height: 8px;
    border-radius: 9999px;
    background: linear-gradient(to right, #f97316 var(--fill, 50%), #26314a var(--fill, 50%));
    outline: none;
  }
  body.page-scheduler input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 9999px;
    background: #fb923c;
    border: 3px solid #0d121b;
    box-shadow: 0 0 0 1px #f97316, 0 2px 8px rgba(0, 0, 0, 0.6);
    cursor: pointer;
  }
  body.page-scheduler input[type='range']::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 9999px;
    background: #fb923c;
    border: 3px solid #0d121b;
    box-shadow: 0 0 0 1px #f97316, 0 2px 8px rgba(0, 0, 0, 0.6);
    cursor: pointer;
  }
</style>

<script>
  import { initCookScheduler } from './cookScheduler.controller.js';
  import { PROTEINS } from '../../utils/proteinRegistry.js';
  import { proteinParam } from '../../utils/shareLink.js';
  document.addEventListener('DOMContentLoaded', () => {
    let raw = null;
    try {
      raw = new URLSearchParams(window.location.search).get('pr');
    } catch (e) {
      /* ignore */
    }
    const id = proteinParam(raw, Object.keys(PROTEINS));
    initCookScheduler(PROTEINS[id]);
  });
</script>
