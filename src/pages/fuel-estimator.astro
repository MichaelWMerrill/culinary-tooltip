---
import Layout from '../layouts/Layout.astro';
import FuelEstimator from '../components/calc/FuelEstimator.astro';
import FaqSection from '../components/calc/FaqSection.astro';

const pageUrl = 'https://empiricalbbq.com/fuel-estimator';
const publisher = {
  '@type': 'Organization',
  name: 'Empirical BBQ',
  url: 'https://empiricalbbq.com/',
  logo: 'https://empiricalbbq.com/android-chrome-512x512.png',
};
const faqs = [
  {
    q: 'How much charcoal do I need for a 12-hour cook?',
    a: 'As a baseline, a single-wall charcoal cooker burning about 1.5 lb/hr over 12 hours in mild weather needs roughly 18 lb of charcoal. Cold, wind, and thin insulation push that higher; the estimator adjusts for all three and tells you how many bags to buy.',
  },
  {
    q: 'How many pellets does a smoker use per hour?',
    a: 'A typical pellet cooker burns around 1.2 lb/hr at a clean 225–250°F in ideal conditions. Freezing temperatures and wind can raise effective consumption by 50% or more.',
  },
  {
    q: 'How does cold weather affect fuel use?',
    a: 'Significantly. The estimator scales burn rate from about 1.0× at 70°F up to roughly 1.75× near 20°F, because the fire has to replace heat lost through the cooker walls. Above about 110°F, ambient solar gain slightly reduces burn.',
  },
  {
    q: 'Does insulation really save fuel?',
    a: 'Yes. Moving from single-wall steel (about 45% efficiency) to an insulated blanket (about 70%) or a ceramic double-wall (about 85%) can cut fuel use by a third or more for the same cook. The what-if panel compares them side by side.',
  },
  {
    q: 'How much does a long smoke cost?',
    a: 'Multiply your effective burn rate by hours and by the cost per pound of fuel. For example, about 14 lb of pellets at roughly $0.90/lb runs near $13 for a 12-hour cook on a single-wall cooker in mild weather — the estimator computes total weight, bags, cost, and cost per hour, and adjusts for insulation, cold, and wind.',
  },
  {
    q: 'Do pellets or charcoal burn more efficiently?',
    a: 'Per pound, hardwood splits carry the most energy (~12,000 BTU/lb), then charcoal (~9,500), then pellets (~8,000). But real-world fuel use depends far more on cooker insulation, weather, and cook length — all of which the estimator models.',
  },
  {
    q: 'How many bags of pellets do I need for an overnight brisket?',
    a: 'For a ~14-hour cook on a single-wall pellet smoker in mild weather, budget roughly 17 lb — about one 20 lb bag. Cold temperatures or wind can push you into a second bag; the estimator adjusts for both.',
  },
];
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Smoker Fuel & Cost Estimator',
    url: pageUrl,
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Any',
    description:
      'Estimate smoker fuel weight, bags, and cost from burn-rate thermodynamics — pit efficiency, ambient temperature, and wind convective heat load.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Layout
  title="Empirical BBQ | Smoker Fuel & Cost Estimator"
  description="Estimate smoker fuel weight, bags, and cost from burn-rate thermodynamics — pit efficiency, ambient temperature, and wind convective heat load."
  ogUrl="https://empiricalbbq.com/fuel-estimator"
  favicon="🪵"
  active="fuel"
  schema={schema}
  bodyClass="page-fuel min-h-screen bg-charcoal-950 text-charcoal-300 font-display antialiased"
>
  <FuelEstimator />
  <FaqSection
    faqs={faqs}
    intro="How much fuel a long cook burns comes down to three things: your fuel's baseline burn rate, how efficiently your pit holds heat, and the weather working against it. A cold, windy day on a thin-walled offset can double consumption versus a still, mild day on an insulated cooker. This estimator turns cook length, pit type, ambient temperature, and wind into the pounds, bags, and dollars you will actually spend — so you buy once and never run dry mid-cook."
  />
</Layout>
