---
import Layout from '../layouts/Layout.astro';
import StallPredictor from '../components/calc/StallPredictor.astro';
import FaqSection from '../components/calc/FaqSection.astro';
import { PROTEINS } from '../utils/proteinRegistry.js';
import { computeModel } from '../utils/stallEngine.js';

// Cook-time figures derived from the engine so the FAQ can't drift from the model.
const tk = (w, pt) =>
  computeModel(
    { weight: w, preparation: 'whole', pitTemp: String(pt), pit: 'offset_smoker', wrap: 'none', climate: 'moderate', wrapTemp: 160 },
    PROTEINS.turkey
  ).totalTime;
const t14at275 = tk(14, 275); // faster end of 250–275°F
const t14at250 = tk(14, 250); // slower end
const tkMplLo = Math.round((t14at275 / 14) * 60);
const tkMplHi = Math.round((t14at250 / 14) * 60);
const tkSpatchcockPct = Math.round((1 - 1 / PROTEINS.turkey.thermal.rate_modifiers.preparation.spatchcock) * 100);

const pageUrl = 'https://empiricalbbq.com/turkey-stall';
const publisher = {
  '@type': 'Organization',
  name: 'Empirical BBQ',
  url: 'https://empiricalbbq.com/',
  logo: 'https://empiricalbbq.com/android-chrome-512x512.png',
};
const faqs = [
  {
    q: 'Does turkey have a stall?',
    a: 'No — poultry climbs steadily to temperature with no evaporative plateau, so the predictor plots a single monotonic curve rather than the stall-and-recover shape of brisket. Cook time is set by weight, preparation, and pit temperature.',
  },
  {
    q: 'What temperature is smoked turkey done?',
    a: 'Pull the breast at 160°F — carryover heat carries it to a safe 165°F. 165°F is the instant pasteurization point, but the USDA also recognizes equivalent time-at-temperature (about 3.7 minutes held at 160°F). Cook the thighs/dark meat toward 175°F for texture.',
  },
  {
    q: 'How long does it take to smoke a turkey?',
    a: `Roughly ${tkMplLo}–${tkMplHi} minutes per pound at 250–275°F for a whole bird; a 14 lb turkey runs about ${t14at275.toFixed(1)}–${t14at250.toFixed(1)} hours. Spatchcocking (backbone removed, laid flat) cuts that meaningfully because the bird heats faster and more evenly.`,
  },
  {
    q: 'Is it safe to smoke a turkey at a low temperature?',
    a: 'FSIS permits smoking poultry at 225–300°F (and roasting at 325°F), so the tool offers all five. The real concern is time in the 40–140°F danger zone: a large whole bird at 225°F can spend many hours there. Spatchcocking or a hotter pit clears the zone much faster, and poultry — treated as potentially contaminated throughout, unlike intact beef — is less forgiving of a long low cook. Always verify with a probe.',
  },
  {
    q: 'Does spatchcocking speed up the cook?',
    a: `Yes. Removing the backbone and flattening the bird exposes more surface area to the heat, so a spatchcocked turkey climbs faster and more evenly than a whole bird — about ${tkSpatchcockPct}% quicker in this model.`,
  },
];
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Turkey Cook-Time Predictor',
    url: pageUrl,
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Any',
    description:
      'Model smoked-turkey cook time as a single monotonic climb (no stall) to a 160°F breast pull, by weight, preparation, and pit temperature, with a food-safety note.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Layout
  title="Empirical BBQ | Smoked Turkey Cook-Time Predictor"
  description="Model smoked-turkey cook time as a single monotonic climb (no stall) to a 160°F breast pull, by weight, whole vs spatchcock, and pit temperature — with a sourced food-safety note."
  ogUrl="https://empiricalbbq.com/turkey-stall"
  schema={schema}
  bodyClass="page-turkey-stall min-h-screen bg-slate-950 text-slate-300 font-display antialiased"
>
  <StallPredictor protein={PROTEINS.turkey} />
  <FaqSection
    faqs={faqs}
    intro="Poultry does not stall — it climbs steadily to the finish, because a turkey is done well before evaporative cooling would ever plateau it. This predictor models smoked-turkey cook time as a single monotonic climb to a 160°F breast pull, where carryover heat carries it to a safe 165°F, based on weight, preparation (whole or spatchcock), and pit temperature."
  />
</Layout>
