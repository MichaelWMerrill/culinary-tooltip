---
import Layout from '../layouts/Layout.astro';
import CookScheduler from '../components/calc/CookScheduler.astro';

const pageUrl = 'https://empiricalbbq.com/cook-scheduler';
const publisher = {
  '@type': 'Organization',
  name: 'Empirical BBQ',
  url: 'https://empiricalbbq.com/',
  logo: 'https://empiricalbbq.com/android-chrome-512x512.png',
};
const faqs = [
  {
    q: 'What time should I start my brisket to eat at a set time?',
    a: 'Work backward: total cook time to a 203°F finish, plus a rest of an hour or more, plus smoker preheat. The scheduler back-calculates all of it from your target serving time and gives you the fire-up time, the wrap window, and when to pull and rest.',
  },
  {
    q: 'How long should a brisket rest before slicing?',
    a: 'At least an hour, and longer is fine — a foil-and-towel cooler hold keeps it safely above 140°F for several hours. The scheduler treats rest as an adjustable block between pulling the meat and serving.',
  },
  {
    q: 'When should I wrap during the cook?',
    a: 'When the bark is set and the internal temperature reaches your wrap target (commonly 150–165°F), which lands inside the stall. The scheduler estimates the clock time you’ll hit that point so you can have paper or foil ready.',
  },
  {
    q: 'Can I add the cook schedule to my calendar?',
    a: 'Yes. Download the .ics file and open it in Apple Calendar, Google Calendar, or Outlook — it adds separate events for fire-up, meat-on, the wrap window, pulling to rest, and serving.',
  },
  {
    q: 'What if my start time is already in the past?',
    a: 'The scheduler flags it: if the required fire-up time has already passed for your target, either move the meal later, raise the pit temperature, or wrap to shorten the cook.',
  },
];
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'BBQ Cook Scheduler',
    url: pageUrl,
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Any',
    description:
      'Back-calculate your smoker fire-up time, wrap window, and rest period from a target serving time — and download the plan as a calendar file.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Layout
  title="Empirical BBQ | BBQ Cook Scheduler — Back-Calculate Your Fire-Up Time"
  description="Enter when you want to eat and get your smoker fire-up time, wrap window, and rest period — back-calculated from the thermodynamic stall model. Download it as a calendar file."
  ogUrl="https://empiricalbbq.com/cook-scheduler"
  active="scheduler"
  schema={schema}
  bodyClass="page-scheduler min-h-screen flex flex-col bg-base-850 text-base-300 font-display antialiased selection:bg-flame-500/30"
  showBanner={false}
>
  <CookScheduler />
</Layout>
