---
import Layout from '../layouts/Layout.astro';
import YieldCalculator from '../components/calc/YieldCalculator.astro';

const pageUrl = 'https://empiricalbbq.com/brisket-calculator';
const publisher = {
  '@type': 'Organization',
  name: 'Empirical BBQ',
  url: 'https://empiricalbbq.com/',
  logo: 'https://empiricalbbq.com/android-chrome-512x512.png',
};
const faqs = [
  {
    q: 'What is the yield of a whole packer brisket?',
    a: 'A whole packer loses weight twice: to trimming (roughly 19–42% depending on USDA grade and how aggressively you trim) and again to evaporation and fat rendering during the cook (about 29–40% of the trimmed weight). A typical 14 lb Choice packer trimmed lightly and cooked in butcher paper finishes near 50% yield — around 7 lb of sliceable brisket.',
  },
  {
    q: 'How much does a brisket shrink when smoked?',
    a: 'Beyond the trim, the cook itself removes roughly 29–40% of the trimmed weight as rendered fat and evaporated moisture. Foil wraps lose the least (the Texas crutch limits evaporation) and naked cooks lose the most.',
  },
  {
    q: 'How do I calculate the true cost per cooked pound?',
    a: 'Divide the raw purchase price by the final cooked weight, not the raw weight. Because total yield is only about 50%, the true cost per cooked pound is often close to double the sticker price per pound.',
  },
  {
    q: 'How much brisket should I cook per person?',
    a: 'Plan about 0.5 lb of cooked, sliced brisket per guest. The serving estimator converts your finished weight into how many guests it covers so you can size the packer to the crowd.',
  },
  {
    q: 'Does USDA grade change the yield?',
    a: 'Yes. The calculator applies grade-specific trim and cook-loss factors — higher grades carry more fat, which changes both how much you trim and how much renders out during the cook.',
  },
  {
    q: 'How much fat should I trim off a brisket?',
    a: 'A light commercial/retail trim removes roughly 19–28% of the raw weight depending on grade; an aggressive competition trim (squared and defatted) removes about 30–42%. The calculator applies your chosen trim style to the raw packer weight.',
  },
  {
    q: 'Does wrapping in foil vs. butcher paper change the yield?',
    a: 'Slightly. Foil (the Texas crutch) limits evaporation and loses the least during the cook (~29–31% of trimmed weight), butcher paper is in the middle (~33–35%), and cooking naked loses the most (~38–40%).',
  },
];
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Brisket Trim, Shrinkage & Yield Calculator',
    url: pageUrl,
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Any',
    description:
      'Model brisket trim loss and evaporative moisture shrinkage during the cook to find usable yield and true cost per cooked pound by weight and USDA grade.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Layout
  title="Empirical BBQ | Brisket Trim, Shrinkage & Yield Calculator"
  description="Model brisket trim loss and evaporative moisture shrinkage during the cook to find usable yield and true cost per cooked pound by weight and USDA grade."
  ogUrl="https://empiricalbbq.com/brisket-calculator"
  favicon="🥩"
  active="brisket"
  schema={schema}
  bodyClass="page-brisket min-h-screen bg-smoke-900 text-smoke-300 font-display antialiased"
>
  <YieldCalculator />
</Layout>
