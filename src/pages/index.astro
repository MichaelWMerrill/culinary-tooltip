---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { MATRIX_PROTEINS, MATRIX_TOOLS, STANDALONE_TOOLS, TOOL_COUNT } from '../utils/toolMatrix.js';
import { SITE_VERSION } from '../utils/version.js';
---

<Layout
  title="Empirical BBQ | Pitmaster Fuel & Yield Calculators"
  description="Physics-based BBQ calculators for brisket, pork, ribs & turkey: yield, the thermodynamic stall, fuel, cost & cook scheduling for precise low-and-slow."
  ogUrl="https://empiricalbbq.com/"
  favicon="🔥"
  active="home"
  bodyClass="page-home min-h-screen flex flex-col bg-base-850 text-base-300 font-display antialiased selection:bg-flame-500/30"
>
  <Fragment slot="head">
    <meta name="impact-site-verification" value="89083931-5f67-460c-970d-1bda9c44e140" />
    <meta name="google-site-verification" content="ZlHhLHpsNb7yx8Ra8AOUL6gmKYA78bkgvrBzhikuyaw" />
  </Fragment>

  <div class="relative z-10 flex-1 w-full">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="pt-14 sm:pt-20 pb-10 sm:pb-12 text-center">
        <div class="inline-flex items-center gap-2 rounded-full bg-flame-500/10 ring-1 ring-flame-500/40 px-3.5 py-1.5 mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-flame-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-flame-500"></span>
          </span>
          <span class="text-xs font-semibold tracking-wide text-flame-300 uppercase">Site v{SITE_VERSION} · Live</span>
        </div>

        <h1 class="text-4xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-white leading-[1.05]">
          PITMASTER<br class="sm:hidden" />
          <span class="bg-gradient-to-r from-flame-500 via-amber-500 to-flame-400 bg-clip-text text-transparent"> COMMAND CENTER</span>
        </h1>

        <p class="mt-5 max-w-2xl mx-auto text-base sm:text-lg text-base-400 leading-relaxed">
          Empirical Data Models &amp; Thermodynamic Calculators for Precision Low-and-Slow Cooking.
        </p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-xs text-base-500">
          <span class="inline-flex items-center gap-1.5 rounded-md bg-base-800 ring-1 ring-base-700 px-3 py-1.5">🔥 {TOOL_COUNT} Calculators</span>
          <span class="inline-flex items-center gap-1.5 rounded-md bg-base-800 ring-1 ring-base-700 px-3 py-1.5">🥩 {MATRIX_PROTEINS.length} Proteins</span>
          <span class="inline-flex items-center gap-1.5 rounded-md bg-base-800 ring-1 ring-base-700 px-3 py-1.5">⚡ Zero-Latency</span>
        </div>
      </header>

      <section class="mb-12 rounded-2xl bg-base-800/60 ring-1 ring-base-700 p-6 shadow-xl shadow-black/30 backdrop-blur-sm">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
          <div class="max-w-md">
            <div class="flex items-center gap-2.5">
              <span class="text-xl">⚙️</span>
              <h2 class="text-lg font-bold text-white">Save My Setup</h2>
              <span id="syncBadge" class="hidden text-[10px] font-bold tracking-wider uppercase bg-emerald-500/10 text-emerald-400 ring-1 ring-emerald-500/30 px-2 py-0.5 rounded-md animate-fade-in">
                Profile Synced
              </span>
            </div>
            <p class="mt-1 text-xs text-base-400 leading-relaxed">
              Lock in your rig configurations. Saved locally in your browser, these preselect the <strong class="text-base-300 font-semibold">Stall Predictor</strong>'s pit type and target temperature and the <strong class="text-base-300 font-semibold">Fuel Estimator</strong>'s fuel type on your first visit — anything you change inside a calculator always takes precedence. (Wood species is saved for upcoming smoke-profile features.)
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 flex-1 max-w-3xl">
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-base-400 mb-1.5">Rig Configuration</label>
              <select id="setupSmoker" class="w-full rounded-lg bg-base-900 border border-base-700 px-3 py-2 text-xs text-white focus:outline-none focus:ring-1 focus:ring-flame-500 transition-all">
                <option value="">-- Select Smoker Rig --</option>
                <option value="Pit Boss Pellet Smoker">Pit Boss Pellet Smoker</option>
                <option value="Traeger Pellet Smoker">Traeger Pellet Smoker</option>
                <option value="Weber Kettle Charcoal Grill">Weber Kettle Charcoal Grill</option>
                <option value="Custom Offset Smoker">Custom Offset Pipe Smoker</option>
              </select>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-base-400 mb-1.5">Primary Wood Species</label>
              <select id="setupWood" class="w-full rounded-lg bg-base-900 border border-base-700 px-3 py-2 text-xs text-white focus:outline-none focus:ring-1 focus:ring-flame-500 transition-all">
                <option value="">-- Select Fuel Wood --</option>
                <option value="Apple Wood">Apple Wood</option>
                <option value="Cherry Wood">Cherry Wood</option>
                <option value="Red Oak">Red Oak Species</option>
                <option value="Hickory">Hickory Species</option>
              </select>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-base-400 mb-1.5">Baseline Target Temp (°F)</label>
              <input id="setupTargetTemp" type="number" placeholder="e.g. 225 or 250" class="w-full rounded-lg bg-base-900 border border-base-700 px-3 py-2 text-xs text-white focus:outline-none focus:ring-1 focus:ring-flame-500 transition-all" />
            </div>
          </div>

          <div class="flex sm:flex-col gap-2 shrink-0 w-full sm:w-auto">
            <button id="saveSetupBtn" class="w-full sm:w-32 bg-gradient-to-r from-flame-600 to-flame-500 hover:from-flame-500 hover:to-flame-400 text-white font-bold text-xs px-4 py-2.5 rounded-lg shadow-md hover:shadow-lg transition-all duration-200">
              Save Profile
            </button>
            <button id="clearSetupBtn" class="w-full sm:w-32 text-base-400 hover:text-white font-semibold text-xs px-4 py-2 rounded-lg transition-colors duration-200">
              Reset Profile
            </button>
          </div>
        </div>
      </section>

      <main class="pb-16">
        <div class="flex items-baseline justify-between gap-4 mb-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-flame-400">Command Center — Calculator Matrix</h2>
          <span class="text-[11px] text-base-500 hidden sm:inline">Pick a protein × tool · every cell is a live page</span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- ============ PROTEIN × TOOL MATRIX ============ -->
          <div class="lg:col-span-2 rounded-2xl bg-base-800/60 ring-1 ring-base-700 shadow-xl shadow-black/30 p-4 sm:p-5 overflow-x-auto">
            <table class="w-full border-collapse text-sm min-w-[520px]">
              <thead>
                <tr>
                  <th class="text-left font-semibold text-base-400 text-[11px] uppercase tracking-wider pb-3 pr-3">Protein</th>
                  {
                    MATRIX_TOOLS.map((t) => (
                      <th class="text-left font-semibold text-base-300 text-xs pb-3 px-2">
                        <span class="inline-flex items-center gap-1.5">
                          <span aria-hidden="true">{t.icon}</span>
                          {t.label}
                        </span>
                        <span class="block font-normal text-[10px] text-base-500 mt-0.5">{t.blurb}</span>
                      </th>
                    ))
                  }
                </tr>
              </thead>
              <tbody>
                {
                  MATRIX_PROTEINS.map((p) => (
                    <tr class="border-t border-base-700/60">
                      <th scope="row" class="text-left font-semibold text-white py-3 pr-3 whitespace-nowrap">
                        <span class="inline-flex items-center gap-2">
                          <span class="text-lg" aria-hidden="true">{p.icon}</span>
                          {p.name}
                        </span>
                      </th>
                      {
                        MATRIX_TOOLS.map((t) =>
                          t.urls[p.id] ? (
                            <td class="py-3 px-2">
                              <a
                                href={t.urls[p.id]}
                                aria-label={`${p.name} — ${t.label}`}
                                class="inline-flex items-center gap-1 rounded-lg bg-base-900/80 ring-1 ring-base-700 hover:ring-flame-500/50 hover:bg-flame-500/10 text-flame-300 hover:text-flame-200 font-medium px-2.5 py-1.5 text-xs transition-all"
                              >
                                Open
                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                              </a>
                            </td>
                          ) : (
                            <td class="py-3 px-2">
                              <span class="text-base-600 text-xs" aria-hidden="true">—</span>
                              <span class="sr-only">No {t.label} calculator for {p.name}</span>
                            </td>
                          )
                        )
                      }
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <!-- ============ AD PLACEMENT (preserved) ============ -->
          <div class="group flex flex-col rounded-2xl bg-base-800/30 ring-1 ring-base-700/40 p-6 border border-dashed border-base-700/50 min-h-[340px] overflow-hidden relative backdrop-blur-[2px]">
            <div class="absolute top-2 right-3 text-[9px] font-mono font-bold uppercase tracking-widest text-base-500">Sponsored Placement</div>
            <div class="flex-1 flex flex-col items-center justify-center text-center p-4">
              <AdSlot
                slotId="home-rectangle-300x250"
                format="rectangle"
                class="w-[300px] h-[250px]"
                style="display:inline-block;width:300px;height:250px"
              />
            </div>
          </div>
        </div>

        <!-- ============ STANDALONE / CROSS-PROTEIN UTILITIES ============ -->
        <h2 class="text-xs font-semibold uppercase tracking-widest text-flame-400 mt-10 mb-5">Planning &amp; Cook-Day Utilities</h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {
            STANDALONE_TOOLS.map((t) => (
              <a
                href={t.href}
                class="card-glow group flex flex-col rounded-2xl bg-base-800/80 ring-1 ring-base-700 p-5 shadow-xl shadow-black/40 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300"
              >
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-flame-500/15 ring-1 ring-flame-500/40 text-2xl mb-4 group-hover:scale-110 transition-transform duration-300">
                  {t.icon}
                </div>
                <h3 class="text-sm font-bold text-white leading-snug">{t.label}</h3>
                <p class="mt-1.5 text-xs text-base-400 leading-relaxed flex-1">{t.blurb}</p>
                <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-flame-400 group-hover:text-flame-300">
                  Open
                  <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </span>
              </a>
            ))
          }
        </div>
      </main>
    </div>
  </div>

  <footer class="relative z-10 border-t border-base-700 bg-base-900/70 backdrop-blur">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-flame-400 mb-3">Mass Transfer</h3>
          <p class="text-[13px] text-base-400 leading-relaxed">
            Yield &amp; shrinkage models apply evaporative mass-loss relations
            (<span class="font-mono text-base-300">ṁ = h<sub>m</sub>·A·Δρ<sub>v</sub></span>) with latent
            heat of vaporization <span class="font-mono text-base-300">L<sub>v</sub></span> to resolve moisture
            profiles across trim and cook phases.
          </p>
        </div>
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-flame-400 mb-3">Convective Heat</h3>
          <p class="text-[13px] text-base-400 leading-relaxed">
            Stall duration is derived from Newton's law of cooling
            (<span class="font-mono text-base-300">q = h<sub>c</sub>·A·(T<sub>pit</sub> − T<sub>meat</sub>)</span>)
            balanced against evaporative flux, scaled by geometric mass exponents
            <span class="font-mono text-base-300">(W<sup>−1/3</sup>)</span>.
          </p>
        </div>
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-flame-400 mb-3">Combustion &amp; Efficiency</h3>
          <p class="text-[13px] text-base-400 leading-relaxed">
            Fuel demand integrates volumetric BTU density against pit thermal
            efficiency <span class="font-mono text-base-300">η</span> and heat-loss coefficient
            <span class="font-mono text-base-300">U</span>, modulated by ambient and wind convective load.
          </p>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-base-800 flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-xs text-base-500">
          &copy; 2026 Pitmaster Science &amp; Mathematics Suite · Site v{SITE_VERSION} · <a href="/contact" class="text-flame-400 hover:text-flame-300 transition-colors">Contact</a> · <a href="/privacy" class="text-flame-400 hover:text-flame-300 transition-colors">Privacy Policy</a>
        </p>
        <p class="text-[11px] text-base-600 font-mono">
          Estimates for planning only — always probe to temperature.
        </p>
      </div>
    </div>
  </footer>
</Layout>

<style is:global>
  body.page-home::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(1200px 600px at 82% -12%, rgba(249, 115, 22, 0.14), transparent 60%),
      radial-gradient(950px 520px at -8% 108%, rgba(245, 158, 11, 0.09), transparent 55%);
  }
  .card-glow:hover {
    box-shadow:
      0 25px 50px -12px rgba(249, 115, 22, 0.22),
      0 0 0 1px rgba(249, 115, 22, 0.35);
  }
  /* animated mock heat curve */
  @keyframes dash {
    to {
      stroke-dashoffset: 0;
    }
  }
  .curve-anim {
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
    animation: dash 2.4s ease forwards;
  }
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(-2px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .animate-fade-in {
    animation: fade-in 0.3s ease both;
  }
</style>

<script is:inline>
  // --- "SAVE MY SETUP" PERSISTENT LOCALSTORAGE PERSISTENCE ENGINE ---
  function saveGlobalSetup() {
    const smoker = document.getElementById('setupSmoker').value;
    const wood = document.getElementById('setupWood').value;
    const targetTemp = document.getElementById('setupTargetTemp').value;

    localStorage.setItem('pitmaster_smoker', smoker);
    // TODO(roadmap): pitmaster_wood is saved but not yet consumed by any calculator.
    // Wire it into wood-species smoke-profile features (see TODO.md #4 — more proteins /
    // smoke modeling) so wood choice influences flavor/stall guidance.
    localStorage.setItem('pitmaster_wood', wood);
    localStorage.setItem('pitmaster_target_temp', targetTemp);

    renderSyncStatus(true);
  }

  function clearGlobalSetup() {
    document.getElementById('setupSmoker').value = '';
    document.getElementById('setupWood').value = '';
    document.getElementById('setupTargetTemp').value = '';

    localStorage.removeItem('pitmaster_smoker');
    localStorage.removeItem('pitmaster_wood');
    localStorage.removeItem('pitmaster_target_temp');

    renderSyncStatus(false);
  }

  function renderSyncStatus(isActive) {
    const badge = document.getElementById('syncBadge');
    const btn = document.getElementById('saveSetupBtn');
    if (isActive) {
      badge.classList.remove('hidden');
      btn.textContent = 'Setup Saved ✓';
      btn.classList.remove('from-flame-600', 'to-flame-500');
      btn.classList.add('bg-emerald-600');
      setTimeout(() => {
        btn.textContent = 'Update Profile';
        btn.classList.add('from-flame-600', 'to-flame-500');
        btn.classList.remove('bg-emerald-600');
      }, 1500);
    } else {
      badge.classList.add('hidden');
      btn.textContent = 'Save Profile';
    }
  }

  function hydrateGlobalSetup() {
    const smoker = localStorage.getItem('pitmaster_smoker');
    const wood = localStorage.getItem('pitmaster_wood');
    const targetTemp = localStorage.getItem('pitmaster_target_temp');

    if (smoker || wood || targetTemp) {
      if (smoker) document.getElementById('setupSmoker').value = smoker;
      if (wood) document.getElementById('setupWood').value = wood;
      if (targetTemp) document.getElementById('setupTargetTemp').value = targetTemp;
      renderSyncStatus(true);
    }
  }

  // Initialize persistent modules on load
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('saveSetupBtn').addEventListener('click', saveGlobalSetup);
    document.getElementById('clearSetupBtn').addEventListener('click', clearGlobalSetup);

    hydrateGlobalSetup();
  });
</script>
