---
import Layout from '../layouts/Layout.astro';
import StallPredictor from '../components/calc/StallPredictor.astro';

const pageUrl = 'https://empiricalbbq.com/stall-predictor';
const publisher = {
  '@type': 'Organization',
  name: 'Empirical BBQ',
  url: 'https://empiricalbbq.com/',
  logo: 'https://empiricalbbq.com/android-chrome-512x512.png',
};
const faqs = [
  {
    q: 'How long does the brisket stall last?',
    a: 'The stall typically sets in between 150°F and 170°F and lasts roughly one to three hours unwrapped, depending on your pit’s airflow and humidity, the meat’s mass, and your climate. Wrapping in butcher paper shortens it, and foil can crush it almost entirely.',
  },
  {
    q: 'What causes the stall?',
    a: 'Evaporative cooling. As internal moisture migrates to the surface and evaporates, it pulls heat away about as fast as the pit adds it, so the internal temperature plateaus until the surface dries out.',
  },
  {
    q: 'Should I wrap to beat the stall?',
    a: 'Foil halts evaporation and powers through the stall fastest but softens the bark; peach butcher paper trims the stall while preserving bark; cooking naked gives the deepest bark but the longest stall. The predictor models all three wrap paths.',
  },
  {
    q: 'How does pit type affect the stall?',
    a: 'Higher-airflow pits such as offset smokers and charcoal kettles drive faster evaporation for a shorter, sharper stall, while low-airflow, higher-humidity cookers like ceramic kamados suppress evaporation and stretch the plateau out.',
  },
  {
    q: 'How long does it take to smoke a brisket?',
    a: 'For a typical 12 lb brisket at 225°F on an offset smoker, expect roughly 8 to 10 hours to reach the 203°F finish, including the stall. Higher pit temperatures and wrapping shorten the total; the predictor plots the full internal-temperature curve.',
  },
  {
    q: 'At what temperature does the brisket stall start?',
    a: 'Most commonly between 150°F and 170°F. The exact onset shifts with climate — drier air intensifies evaporative cooling and lowers it (nearer 145°F), while humid air suppresses evaporation and raises it (nearer 162°F).',
  },
  {
    q: 'Why is my brisket taking so long?',
    a: 'Usually the stall, amplified by a large or wide cut, a humid environment, or a low-airflow cooker. The predictor splits the cook into initial climb, stall, and final climb so you can see exactly where the time is going.',
  },
];
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Thermodynamic Stall Predictor',
    url: pageUrl,
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Any',
    description:
      'Model the evaporative-cooling stall: plot internal temperature versus time and predict stall duration from pit convection, humidity, wrap method, and meat mass.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Layout
  title="Empirical BBQ | Brisket Stall Predictor & Cook-Time Curve"
  description="Model the evaporative-cooling stall: plot internal temperature versus time and predict stall duration from pit convection, humidity, wrap method, and meat mass."
  ogUrl="https://empiricalbbq.com/stall-predictor"
  favicon="📈"
  active="stall"
  schema={schema}
  bodyClass="page-stall min-h-screen bg-slate-950 text-slate-300 font-display antialiased"
>
  <StallPredictor />
</Layout>
